---
import DownloadButton from './DownloadButton.astro';
import WaveformIcon from './WaveformIcon.astro';
---

<section class="py-20 px-6 bg-white">
  <div class="max-w-3xl mx-auto text-center">
    <h2 class="text-3xl font-bold mb-4">Ready to try it?</h2>
    <p class="text-lg text-gray-600 mb-8">Download WhisperFree and start dictating in under a minute.</p>
    <DownloadButton size="lg" />
    <p class="text-sm text-gray-400 mt-4">macOS 14+ &middot; Apple Silicon required &middot; ~150 MB</p>
  </div>
</section>

<footer class="py-8 px-6 border-t border-gray-100">
  <div class="max-w-5xl mx-auto flex flex-col sm:flex-row items-center justify-between gap-4 text-sm text-gray-400">
    <div class="flex items-center gap-2">
      <WaveformIcon size={16} class="text-gray-400" />
      <span>WhisperFree</span>
    </div>
    <div class="flex items-center gap-6">
      <span>&copy; {new Date().getFullYear()} WhisperFree</span>
    </div>
  </div>
</footer>
