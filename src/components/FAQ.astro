---
const faqs = [
  {
    q: "Is it really free?",
    a: "Yes. No trial, no account. The core app will always be free; optional upgrades may come later."
  },
  {
    q: "How fast is it?",
    a: "By the time you've let go of the key, your words are at the cursor. No upload, no spinner."
  },
  {
    q: "How accurate is it?",
    a: "Noticeably better than built-in Mac dictation. Add your own vocabulary and shortcuts to push it further."
  },
  {
    q: "Does it work offline?",
    a: "Yes. After a one-time model download on first launch, no internet is needed."
  },
  {
    q: "What languages are supported?",
    a: "English only for now. More languages later."
  },
  {
    q: "Is it open source?",
    a: "Not currently. The app is free to use and built on open-source voice models."
  },
  {
    q: "How is this different from built-in Mac dictation?",
    a: "It's faster, more accurate, and you can teach it. Add your vocabulary and write your own auto-corrections so it gets your names, jargon, and quirks right. Built-in dictation does none of that."
  },
  {
    q: "How does this compare to Wispr Flow, Superwhisper, or Aqua Voice?",
    a: "Wispr Flow and Aqua Voice are paid cloud services — fast and polished, but your audio leaves your Mac and you pay every month. Superwhisper is on-device like us, but also paid. Of the three, WhisperFree is the only one that's both free and fully on your Mac."
  },
];
---

<section id="faq" class="py-20 px-6 bg-gray-50">
  <div class="max-w-3xl mx-auto">
    <h2 class="text-3xl font-bold text-center mb-12">Frequently asked questions</h2>

    <div class="space-y-6">
      {faqs.map(({ q, a }) => (
        <details class="bg-white rounded-xl border border-gray-200 group">
          <summary class="px-6 py-4 cursor-pointer font-semibold text-gray-900 flex items-center justify-between list-none">
            {q}
            <svg class="w-5 h-5 text-gray-400 transition-transform group-open:rotate-180 shrink-0 ml-4" viewBox="0 0 20 20" fill="none">
              <path d="M5 7l5 5 5-5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </summary>
          <div class="px-6 pb-4 text-gray-600">
            {a}
          </div>
        </details>
      ))}
    </div>
  </div>
</section>
