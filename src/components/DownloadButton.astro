---
interface Props {
  size?: 'sm' | 'lg';
  class?: string;
}

const { size = 'lg', class: className = '' } = Astro.props;

const sizeClasses = size === 'lg'
  ? 'px-8 py-4 text-lg'
  : 'px-5 py-2 text-sm';
---

<a
  href="/download"
  class:list={[
    'inline-flex items-center gap-2 bg-teal-600 text-white font-semibold rounded-xl no-underline transition-all hover:bg-teal-700 hover:shadow-lg hover:shadow-teal-600/20 active:scale-95',
    sizeClasses,
    className,
  ]}
>
  <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
    <path d="M8 1v10M4 7l4 4 4-4M2 13h12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
  </svg>
  Download Free
</a>
