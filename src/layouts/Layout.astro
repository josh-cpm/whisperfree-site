---
import '../styles/global.css';
import fs from 'node:fs';
import path from 'node:path';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'WhisperFree — Fast, Private Dictation for Mac',
  description = 'A free, private alternative to Wispr Flow, Superwhisper, and Aqua Voice. Hold Fn to dictate — your words land at the cursor, never leave your Mac.',
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const ogImage = new URL('/og-image.png', Astro.site);

let appVersion = '1.0';
try {
  const appcast = fs.readFileSync(path.join(process.cwd(), 'public', 'appcast.xml'), 'utf-8');
  const match = appcast.match(/<sparkle:shortVersionString>([^<]+)<\/sparkle:shortVersionString>/);
  if (match) appVersion = match[1];
} catch {}
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="apple-touch-icon" sizes="512x512" href="/apple-touch-icon.png" />
    <link rel="canonical" href={canonicalURL} />

    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="keywords" content="fastest dictation mac, local voice to text mac, parakeet tdt mac, low latency dictation, on-device speech to text, custom vocabulary dictation, apple silicon transcription, offline dictation mac" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:site_name" content="WhisperFree" />
    <meta property="og:title" content="Fast dictation. Fully private. Free." />
    <meta property="og:description" content="A free, private alternative to Wispr Flow, Superwhisper, and Aqua Voice. Local on your Mac. Free." />
    <meta property="og:image" content={ogImage} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="Fast dictation. Fully private. Free." />
    <meta name="twitter:description" content="A free, private alternative to Wispr Flow, Superwhisper, and Aqua Voice. Local on your Mac. Free." />
    <meta name="twitter:image" content={ogImage} />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />

    <!-- JSON-LD Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "SoftwareApplication",
      "name": "WhisperFree",
      "operatingSystem": "macOS 14.0+",
      "applicationCategory": "UtilitiesApplication",
      "offers": {
        "@type": "Offer",
        "price": "0",
        "priceCurrency": "USD"
      },
      "description": description,
      "downloadUrl": "https://whisperfree.com/download",
      "softwareVersion": appVersion,
      "fileSize": "150MB",
      "softwareRequirements": "macOS 14.0 or later, Apple Silicon required"
    })} />
  </head>
  <body class="bg-white text-gray-900 font-sans antialiased">
    <slot />
  </body>
</html>
